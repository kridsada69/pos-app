generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  email     String   @unique
  mobile    String   @unique
  password  String
  role      String   @default("employee")
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  orders    Order[]
  activityLogs ActivityLog[]
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  username   String?
  userName   String?
  userRole   String?
  action     String
  entity     String
  entityId   String?
  summary    String
  route      String
  httpMethod String
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([action, entity])
}

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  stock      Int         @default(0)
  price      Float
  cost       Float
  category   String
  imageUrl   String?
  imageIcon  String?
  company    String?
  status     String      @default("active")
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  promotions PromotionProduct[]
  giftCampaigns GiftCampaignProduct[]

  @@index([status, deletedAt])
  @@index([category])
  @@index([company])
}

model Order {
  id                Int         @id @default(autoincrement())
  total             Float
  cashierId         Int
  slipUrl           String?
  status            String      @default("active")
  createdAt         DateTime    @default(now())
  manualDiscount    Float       @default(0)
  note              String?
  promotionDiscount Float       @default(0)
  promotionLabel    String?
  promotionId       Int?
  subtotal          Float       @default(0)
  tax               Float       @default(0)
  cashier           User        @relation(fields: [cashierId], references: [id])
  items             OrderItem[]
  promotion         Promotion?  @relation(fields: [promotionId], references: [id])
  giftSelections    OrderGiftSelection[]

  @@index([status, createdAt])
  @@index([cashierId])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  cost      Float   @default(0)
  productName String   @default("")
  company   String?
  category  String?
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  icon      String   @default("📦")
  createdAt DateTime @default(now())

  @@unique([name, icon])
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  expenseEntries ExpenseEntryCompany[]
}

model Promotion {
  id                  Int                @id @default(autoincrement())
  name                String
  requiredQuantity    Int
  bundlePrice         Float
  appliesToAllProducts Boolean           @default(false)
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  products            PromotionProduct[]
  orders              Order[]

  @@index([isActive, updatedAt])
}

model PromotionProduct {
  promotionId Int
  productId   Int
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
}

model GiftCampaign {
  id                   Int                   @id @default(autoincrement())
  name                 String
  giftName             String
  cost                 Float
  requiredQuantity     Int                   @default(1)
  appliesToAllProducts Boolean               @default(false)
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  products             GiftCampaignProduct[]
  orderSelections      OrderGiftSelection[]

  @@index([isActive, updatedAt])
}

model GiftCampaignProduct {
  giftCampaignId Int
  productId      Int
  giftCampaign   GiftCampaign @relation(fields: [giftCampaignId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([giftCampaignId, productId])
}

model OrderGiftSelection {
  id               Int          @id @default(autoincrement())
  orderId          Int
  giftCampaignId   Int
  giftCampaignName String
  giftName         String
  cost             Float
  quantity         Int          @default(1)
  createdAt        DateTime     @default(now())
  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  giftCampaign     GiftCampaign @relation(fields: [giftCampaignId], references: [id])

  @@unique([orderId, giftCampaignId])
}

model ExpenseEntry {
  id          Int      @id @default(autoincrement())
  name        String
  amount      Float
  company     String?
  note        String?
  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  companies   ExpenseEntryCompany[]

  @@index([expenseDate])
  @@index([company])
}

model ExpenseEntryCompany {
  expenseEntryId Int
  companyId      Int
  expenseEntry   ExpenseEntry @relation(fields: [expenseEntryId], references: [id], onDelete: Cascade)
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([expenseEntryId, companyId])
}
